# 1. Local Simulation Data
# Ignores the dummy datasets generated by local_simulation/generate_dummy_data.py
local_simulation/dummy_data/
*.parquet
*.csv

# 2. Model Submissions and Checkpoints
# Ignores the final aggregated model saved by custom_strategy.py
submission/
*.pkl
*.pt
*.pth
*.h5
*.joblib
*.ckpt
saved_models/
checkpoints/

# 3. Python Environments and Cache
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# 4. Jupyter Notebooks
.ipynb_checkpoints/

# 5. OS and IDE generated files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
.vscode/
.idea/
*.swp